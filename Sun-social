<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<title>🌞 SunSocial — Mobile Demo</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
<style>
  :root{
    --sun:#FF6B35; --sun2:#FFD23F; --bg:#FFF6E9; --muted:#7a7a7a;
    --card-shadow: 0 6px 18px rgba(0,0,0,0.06);
  }
  *{box-sizing:border-box}
  html,body{height:100%;margin:0;font-family:Inter, Poppins, system-ui, sans-serif;background:var(--bg);color:#222;-webkit-font-smoothing:antialiased;}
  /* STATUS + APPBAR */
  .status{position:fixed;top:0;left:0;right:0;height:22px;background:var(--sun);color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 12px;font-size:12px;z-index:40}
  .appbar{position:fixed;top:22px;left:0;right:0;height:58px;background:#fff;display:flex;align-items:center;padding:8px 12px;z-index:39;border-bottom:1px solid #eee; gap:12px}
  .brand{font-weight:700;color:var(--sun);font-size:18px}
  .app-actions{margin-left:auto;display:flex;gap:8px;align-items:center}
  button.icon{background:none;border:none;font-size:18px;color:var(--muted)}
  /* MAIN */
  main{padding:96px 12px 110px;max-width:820px;margin:0 auto}
  .card{background:#fff;border-radius:14px;padding:12px;margin-bottom:12px;box-shadow:var(--card-shadow)}
  .create-row{display:flex;gap:10px;align-items:flex-start}
  .avatar-sm{width:46px;height:46px;border-radius:50%;object-fit:cover}
  .post-textarea{flex:1;border-radius:12px;border:1px solid #f0f0f0;padding:10px;background:#fbfbfb;min-height:48px;resize:none}
  .post-controls{display:flex;justify-content:space-between;align-items:center;margin-top:8px}
  .btn{padding:8px 12px;border-radius:10px;border:none;cursor:pointer}
  .btn.primary{background:var(--sun);color:#fff}
  .btn.ghost{background:transparent;border:1px solid #eee}
  .media-preview{display:flex;gap:8px;margin-top:8px;overflow:auto}
  .media-thumb{width:72px;height:72px;border-radius:8px;object-fit:cover;flex-shrink:0}
  /* POST */
  .post-card{border-radius:14px;overflow:hidden}
  .post-header{display:flex;gap:10px;align-items:center}
  .post-name{font-weight:600}
  .post-time{font-size:12px;color:var(--muted)}
  .post-body{margin-top:8px}
  .post-image{width:100%;border-radius:10px;margin-top:8px;max-height:420px;object-fit:cover}
  .post-actions{display:flex;gap:8px;padding-top:10px;border-top:1px solid #f5f5f5;margin-top:10px;align-items:center}
  .like-btn{display:flex;align-items:center;gap:8px;border-radius:10px;padding:8px 10px;border:none;background:transparent;color:var(--muted);cursor:pointer}
  .like-btn.liked{background:linear-gradient(90deg,var(--sun),var(--sun2));color:#fff;transform:scale(1.03);box-shadow:0 8px 24px rgba(255,107,53,0.14)}
  .heart-burst{position:absolute;transform:translate(-50%,-120%) scale(0);left:50%;top:0;pointer-events:none;font-size:20px}
  .like-wrapper{position:relative}
  /* COMMENTS */
  .comment-section{background:#fafafa;border-radius:12px;padding:10px;margin-top:8px}
  .comment-row{display:flex;gap:8px;margin-top:8px;align-items:flex-start}
  .comment-bubble{background:#fff;padding:8px;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.04)}
  /* FRIENDS */
  .friends-panel{position:fixed;right:12px;bottom:110px;width:320px;max-width:calc(100% - 24px);z-index:45}
  .friend-item{display:flex;gap:10px;align-items:center;padding:8px;border-bottom:1px solid #f5f5f5}
  .friend-btn{margin-left:auto;padding:6px 10px;border-radius:8px;border:none;cursor:pointer}
  /* CHAT MODAL */
  .chat-modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.98);z-index:9999;display:none;flex-direction:column}
  .chat-header{background:linear-gradient(90deg,var(--sun),var(--sun2));color:#fff;padding:12px;display:flex;gap:8px;align-items:center}
  .chat-messages{flex:1;padding:12px;overflow:auto;background:#f8f8f8}
  .chat-row{display:flex;margin-bottom:8px}
  .chat-row.me{justify-content:flex-end}
  .chat-bubble{max-width:75%;padding:10px;border-radius:16px}
  .chat-bubble.me{background:linear-gradient(90deg,var(--sun),var(--sun2));color:#fff}
  .chat-bubble.them{background:#fff;border:1px solid #eee}
  .chat-input-area{display:flex;gap:8px;padding:12px;border-top:1px solid #eee}
  .chat-input{flex:1;padding:10px;border-radius:999px;border:1px solid #ddd}
  /* PROFILE MODAL */
  .modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.4);display:none;align-items:center;justify-content:center;z-index:9998}
  .modal{width:92%;max-width:480px;background:#fff;border-radius:12px;padding:14px}
  .profile-edit{display:flex;gap:12px;align-items:center}
  .profile-avatar{width:84px;height:84px;border-radius:50%;object-fit:cover}
  /* BOTTOM NAV + FAB */
  .bottom-nav{position:fixed;left:0;right:0;bottom:0;background:#fff;padding:8px 10px;display:flex;justify-content:space-around;gap:8px;border-top:1px solid #eee;z-index:50}
  .nav-item{display:flex;flex-direction:column;align-items:center;font-size:12px;color:var(--muted)}
  .nav-item.active{color:var(--sun)}
  .fab{position:fixed;right:16px;bottom:86px;background:var(--sun);color:#fff;width:56px;height:56px;border-radius:50%;border:none;font-size:24px;box-shadow:0 8px 26px rgba(255,107,53,0.16);z-index:51}
  /* ANIMATIONS */
  .fade-in{animation:ai .32s ease both}
  @keyframes ai{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .pulse{animation:pulse .5s ease}
  @keyframes pulse{50%{transform:scale(1.08)}}
  /* UTIL */
  .small{font-size:12px;color:var(--muted)}
  input[type=file]{display:none}
  @media(min-width:900px){
    main{padding-left:40px;padding-right:40px}
  }
</style>
</head>
<body>

  <div class="status"><div id="clock">--:--</div><div class="small">SunSocial</div></div>

  <div class="appbar">
    <div class="brand">🌞 SunSocial</div>
    <div style="display:flex;gap:8px;align-items:center" class="app-actions">
      <button class="icon" id="openFriends" title="Friends"><i class="fas fa-user-friends"></i></button>
      <button class="icon" id="openProfile" title="Profile"><i class="fas fa-user-circle"></i></button>
      <button class="icon" id="openChatList" title="Chats"><i class="fas fa-comments"></i></button>
    </div>
  </div>

  <main>
    <!-- CREATE POST -->
    <div class="card create-card fade-in" id="composer">
      <div class="create-row">
        <img id="meAvatar" class="avatar-sm" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face" alt="me">
        <div style="flex:1">
          <textarea id="inputPost" class="post-textarea" placeholder="What's on your mind?"></textarea>
          <div class="media-preview" id="mediaPreview"></div>
          <div class="post-controls">
            <div style="display:flex;gap:6px;align-items:center">
              <label class="btn ghost" for="imgInput"><i class="fas fa-image"></i></label>
              <label class="btn ghost" for="videoInput"><i class="fas fa-video"></i></label>
              <input id="imgInput" type="file" accept="image/*" multiple>
              <input id="videoInput" type="file" accept="video/*">
              <button class="btn ghost" id="clearMedia">Clear</button>
            </div>
            <div>
              <button class="btn primary" id="publishPost">Publish</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- FEED -->
    <div id="postsFeed"></div>
  </main>

  <!-- FRIENDS PANEL -->
  <div class="friends-panel" id="friendsPanel" style="display:none;">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <strong>Friends</strong>
        <button class="btn ghost" id="addRandomFriend">Add Random</button>
      </div>
      <div id="friendsList" style="margin-top:8px"></div>
    </div>
  </div>

  <!-- CHAT LIST MODAL -->
  <div class="modal-bg" id="chatListModal" style="display:none;">
    <div class="modal">
      <div style="display:flex;justify-content:space-between;align-items:center"><strong>Chats</strong><button class="btn ghost" id="closeChatList">Close</button></div>
      <div id="chatList" style="margin-top:8px"></div>
    </div>
  </div>

  <!-- CHAT WINDOW -->
  <div class="chat-modal" id="chatModal">
    <div class="chat-header">
      <button class="icon" id="closeChat" style="color:#fff"><i class="fas fa-arrow-left"></i></button>
      <div id="chatWith" style="font-weight:600"></div>
    </div>
    <div class="chat-messages" id="chatMessages"></div>
    <div class="chat-input-area">
      <input id="chatText" class="chat-input" placeholder="Type a message..." onkeypress="if(event.key==='Enter')sendChat()">
      <button class="btn primary" id="sendChatBtn">Send</button>
    </div>
  </div>

  <!-- PROFILE EDIT MODAL -->
  <div class="modal-bg" id="profileModal" style="display:none;">
    <div class="modal">
      <div style="display:flex;justify-content:space-between;align-items:center"><strong>Edit Profile</strong><button class="btn ghost" id="closeProfileModal">Close</button></div>
      <div class="profile-edit" style="margin-top:12px">
        <img id="profileAvatar" class="profile-avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face" alt="avatar">
        <div style="flex:1">
          <input id="profileName" placeholder="Your name" style="width:100%;padding:8px;border-radius:8px;border:1px solid #eee">
          <input id="profileBio" placeholder="Short bio" style="width:100%;padding:8px;border-radius:8px;border:1px solid #eee;margin-top:8px">
          <div style="display:flex;gap:8px;margin-top:8px;align-items:center">
            <label class="btn ghost" for="avatarInput">Upload Avatar</label>
            <input id="avatarInput" type="file" accept="image/*">
            <button class="btn primary" id="saveProfile">Save</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- BOTTOM NAV + FAB -->
  <div class="bottom-nav">
    <div class="nav-item active" id="navHome"><i class="fas fa-home"></i><div class="small">Home</div></div>
    <div class="nav-item" id="navFriends"><i class="fas fa-user-friends"></i><div class="small">Friends</div></div>
    <div class="nav-item" id="navChat"><i class="fas fa-comments"></i><div class="small">Chats</div></div>
    <div class="nav-item" id="navProfileBtn"><i class="fas fa-user"></i><div class="small">Profile</div></div>
  </div>
  <button class="fab" id="fabNew">✚</button>

<script>
/* ---------------------------
  Simple local-only SunSocial
  - localStorage used for posts, profile, friends, chats
----------------------------*/
const UID = 'local_user'; // single demo user id
// state
let state = {
  profile: {name:'M D Tanvir', bio:'Shining every day! ☀️', photo:'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face'},
  friends: [],
  posts: [],
  chats: {} // { friendName: [{from:'me'|'them', text, at}]}
}

// clock
setInterval(()=>document.getElementById('clock').textContent = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}), 1000);

// helpers
const $ = sel => document.querySelector(sel);
const $$ = sel => document.querySelectorAll(sel);

function saveState(){ localStorage.setItem('sunsocial_v1', JSON.stringify(state)); }
function loadState(){ const v = localStorage.getItem('sunsocial_v1'); if(v){ state = JSON.parse(v); } else { seedDemo(); saveState(); } }
function uid(){ return Math.random().toString(36).slice(2,9); }
function timeAgo(ts){
  if(!ts) return ''; const d = Date.now() - ts; if(d<60000) return Math.floor(d/1000)+'s'; if(d<3600000) return Math.floor(d/60000)+'m';
  if(d<86400000) return Math.floor(d/3600000)+'h'; return Math.floor(d/86400000)+'d';
}
function escapeHtml(s){ if(!s) return ''; return s.replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;'); }

/* ---------- DEMO SEED ---------- */
function seedDemo(){
  state.profile = {name:'M D Tanvir', bio:'Shining every day! ☀️', photo:'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face'};
  state.friends = [
    {id:uid(), name:'Zakia Khatun', avatar:'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=120&h=120&fit=crop&crop=face'},
    {id:uid(), name:'Riya Sen', avatar:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=120&h=120&fit=crop&crop=face'},
    {id:uid(), name:'Asif Mahmud', avatar:'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=120&h=120&fit=crop&crop=face'}
  ];
  state.posts = [
    {id:uid(), author:state.profile, text:'☀️ Good morning everyone!', media:[], likes:[], comments:[], at:Date.now()-3600000},
    {id:uid(), author:state.friends[0], text:'📸 Golden hour shot!', media:[{type:'image',url:'https://picsum.photos/600/320?random=11'}], likes:[], comments:[], at:Date.now()-7200000},
    {id:uid(), author:state.friends[1], text:'🎥 Short travel clip', media:[{type:'video',url:'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4'}], likes:[], comments:[], at:Date.now()-36000000}
  ];
  state.chats = {
    [state.friends[0].name]: [{from:'them', text:'হাই! কেমন?', at:Date.now()-600000}],
    [state.friends[1].name]: [{from:'them', text:'ভিডিওটা দারুণ!', at:Date.now()-1200000}]
  };
}

/* ---------- STORAGE ---------- */
loadState();

/* ---------- RENDER PROFILE ---------- */
function renderProfileUI(){
  $('#meAvatar').src = state.profile.photo;
  $('#profileAvatar').src = state.profile.photo;
  $('#profileName').value = state.profile.name;
  $('#profileBio').value = state.profile.bio;
}

/* ---------- FRIENDS ---------- */
function renderFriends(){
  const list = $('#friendsList');
  list.innerHTML = '';
  state.friends.forEach(f=>{
    const row = document.createElement('div'); row.className='friend-item';
    row.innerHTML = `<img src="${f.avatar}" style="width:44px;height:44px;border-radius:50%;object-fit:cover"><div><strong>${f.name}</strong><div class="small">Friend</div></div><button class="friend-btn" data-id="${f.id}">Remove</button>`;
    list.appendChild(row);
    row.querySelector('.friend-btn').addEventListener('click',ev=>{
      const id = ev.target.dataset.id;
      state.friends = state.friends.filter(x=>x.id!==id);
      saveState(); renderFriends(); renderChatList(); renderFeed();
    });
  });
  if(state.friends.length===0){
    list.innerHTML = '<div class="small muted">No friends yet. Add some!</div>';
  }
}

/* ---------- CHATS ---------- */
function renderChatList(){
  const el = $('#chatList');
  el.innerHTML = '';
  const names = Object.keys(state.chats || {});
  const friendsNames = state.friends.map(f=>f.name);
  const combined = Array.from(new Set([...friendsNames, ...names]));
  combined.forEach(name=>{
    const last = (state.chats[name]||[]).slice(-1)[0];
    const row = document.createElement('div'); row.className='friend-item';
    row.innerHTML = `<div style="display:flex;flex-direction:column"><strong>${name}</strong><div class="small">${last?last.text:''}</div></div><button class="btn ghost" style="margin-left:auto">Open</button>`;
    el.appendChild(row);
    row.querySelector('button').addEventListener('click',()=>openChat(name));
  });
}

/* ---------- CHAT WINDOW ---------- */
let currentChat = null;
function openChat(name){
  currentChat = name;
  $('#chatWith').textContent = name;
  $('#chatModal').style.display = 'flex';
  renderChatMessages();
}
function closeChat(){
  $('#chatModal').style.display = 'none';
  currentChat = null;
}
function renderChatMessages(){
  const area = $('#chatMessages');
  area.innerHTML = '';
  const msgs = state.chats[currentChat] || [];
  msgs.forEach(m=>{
    const r = document.createElement('div'); r.className = 'chat-row ' + (m.from==='me'?'me':'them');
    r.innerHTML = `<div class="chat-bubble ${m.from==='me'?'me':'them'}">${escapeHtml(m.text)}<div class="small" style="margin-top:6px;font-size:10px;color:#999">${new Date(m.at).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</div></div>`;
    area.appendChild(r);
  });
  area.scrollTop = area.scrollHeight;
}
function sendChat(){
  const txt = $('#chatText').value.trim(); if(!txt || !currentChat) return;
  const msg = {from:'me', text:txt, at:Date.now()};
  state.chats[currentChat] = state.chats[currentChat] || [];
  state.chats[currentChat].push(msg);
  saveState();
  $('#chatText').value = '';
  renderChatMessages();
  // auto reply simulation
  setTimeout(()=>{
    const reply = {from:'them', text: ['Nice!','Awesome!','🙂','Great!'][Math.floor(Math.random()*4)], at:Date.now()};
    state.chats[currentChat].push(reply); saveState(); renderChatMessages();
  }, 800 + Math.random()*1000);
}

/* ---------- POSTS ---------- */
function renderFeed(){
  const feed = document.getElementById('postsFeed'); feed.innerHTML = '';
  // sort desc by at
  state.posts.sort((a,b)=>b.at - a.at);
  state.posts.forEach(p=>{
    const card = document.createElement('div'); card.className = 'card post-card fade-in';
    const mediaHtml = (p.media||[]).map(m=>{
      if(m.type==='image') return `<img src="${m.url}" class="post-image">`;
      if(m.type==='video') return `<video src="${m.url}" class="post-image" controls playsinline></video>`;
      return '';
    }).join('');
    card.innerHTML = `
      <div class="post-header">
        <img src="${p.author.photo}" style="width:46px;height:46px;border-radius:50%;object-fit:cover">
        <div style="flex:1">
          <div class="post-name">${escapeHtml(p.author.name)}</div>
          <div class="post-time small" id="time_${p.id}">${timeAgo(p.at)} ago</div>
        </div>
      </div>
      <div class="post-body">
        <div class="post-text small" style="margin-top:8px">${escapeHtml(p.text || '')}</div>
        ${mediaHtml}
        <div class="post-actions">
          <div class="like-wrapper">
            <button class="like-btn ${p.likes.includes(UID)?'liked':''}" data-id="${p.id}"><i class="fas fa-heart"></i> <span class="like-count">${p.likes.length}</span></button>
            <div class="heart-burst" id="hb_${p.id}">💖</div>
          </div>
          <button class="btn ghost comment-toggle" data-id="${p.id}"><i class="fas fa-comment"></i> Comment</button>
          <button class="btn ghost share-btn" data-id="${p.id}"><i class="fas fa-share"></i> Share</button>
        </div>
        <div class="comment-section" id="c_${p.id}" style="display:none">
          <div id="comments_list_${p.id}"></div>
          <div class="comment-row"><input placeholder="Write a comment..." class="comment-input" data-id="${p.id}"><button class="btn primary add-comment" data-id="${p.id}">Send</button></div>
        </div>
      </div>
    `;
    feed.appendChild(card);

    // events
    card.querySelectorAll('.like-btn').forEach(btn=>{
      btn.addEventListener('click',ev=>{
        const id = ev.currentTarget.dataset.id;
        toggleLike(id, ev.currentTarget);
      });
    });
    card.querySelectorAll('.comment-toggle').forEach(btn=>btn.addEventListener('click',ev=>{
      const id = ev.currentTarget.dataset.id;
      const el = document.getElementById('c_'+id);
      el.style.display = el.style.display==='none'?'block':'none';
      renderComments(id);
    }));
    card.querySelectorAll('.add-comment').forEach(b=>b.addEventListener('click',ev=>{
      const id = ev.currentTarget.dataset.id;
      const inp = document.querySelector(`.comment-input[data-id="${id}"]`);
      submitComment(id, inp.value);
      inp.value='';
    }));
    // update time label periodically
    const tEl = document.getElementById('time_'+p.id);
    setInterval(()=>{ if(tEl) tEl.textContent = timeAgo(p.at)+' ago'; }, 30000);
    renderComments(p.id);
  });

  // no posts
  if(state.posts.length===0) document.getElementById('postsFeed').innerHTML = '<div class="card small muted">No posts
